# Database Configuration (Neon PostgreSQL)
# Get this from your Neon dashboard: https://console.neon.tech/
# Example: postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# Authentication
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration (Production URLs)
FRONTEND_URL=https://your-frontend-domain.netlify.app
ADMIN_URL=https://your-admin-domain.netlify.app
BACKEND_URL=https://your-backend-domain.onrender.com

# Optional: Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Debug Mode
DEBUG=false
