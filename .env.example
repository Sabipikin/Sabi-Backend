# Production Database Configuration
# Use a cloud-hosted PostgreSQL service (Render, Neon, Supabase, Railway, etc.)
# Example: postgresql://username:password@hostname:5432/database_name
DATABASE_URL=postgresql://user:password@localhost:5432/sabipath

# Production Settings
DEBUG=False

# Optional Supabase settings for hosted Supabase features and storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key
