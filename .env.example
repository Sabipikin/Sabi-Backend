# Database Configuration (Neon PostgreSQL)
# Get this from your Neon dashboard: https://console.neon.tech/
DATABASE_URL=postgresql://neondb_owner:npg_rFLnJj8KDN4b@ep-lucky-cake-amc7u8dr-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Authentication
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration (Production URLs)
FRONTEND_URL=https://sabieducate.netlify.app
ADMIN_URL=https://sabiadmin.netlify.app
BACKEND_URL=https://your-backend-domain.onrender.com

# Debug Mode
DEBUG=false

# ============================================
# PAYONEER PAYMENT GATEWAY CONFIGURATION
# ============================================
# Get these credentials from Payoneer Business API dashboard
# https://www.payoneer.com/business/

# Payoneer API Base URL
# Production: https://api.payoneer.com/v2
# Sandbox: https://sandbox.payoneer.com/v2
PAYONEER_API_URL=https://api.payoneer.com/v2

# Payoneer OAuth Credentials (from Business API settings)
# These are used for Client Credentials Grant flow
PAYONEER_CLIENT_ID=your_payoneer_client_id_here
PAYONEER_CLIENT_SECRET=your_payoneer_client_secret_key_here

# Payoneer Partner ID
# Your unique identifier assigned by Payoneer
PAYONEER_PARTNER_ID=your_payoneer_partner_id_here

# Payoneer Webhook Secret
# Used to verify incoming webhook signatures from Payoneer
# Generate this in your Payoneer Business dashboard under Webhooks
PAYONEER_WEBHOOK_SECRET=your_payoneer_webhook_secret_key_here

# ============================================
# EMAIL CONFIGURATION (For Payment Notifications)
# ============================================
# SMTP Configuration for sending payment confirmation/receipt emails
# We recommend using Gmail or a dedicated email service

# SMTP Server
# Gmail: smtp.gmail.com
# SendGrid: smtp.sendgrid.net
# Custom: your-mail-server.com
SMTP_SERVER=smtp.gmail.com

# SMTP Port
# Gmail: 587 (TLS) or 465 (SSL)
# SendGrid: 587
SMTP_PORT=587

# Sender Email Address
# The email address that payment notifications will be sent from
SENDER_EMAIL=noreply@sabieducate.com

# SMTP Password/API Key
# For Gmail: Use App Password (not your regular password)
# For SendGrid: Use API Key
# Generate at: https://myaccount.google.com/apppasswords (Gmail)
SENDER_PASSWORD=your_app_password_or_api_key_here

# Sender Name
# Display name for outgoing payment emails
SENDER_NAME=Sabi Educate

# Support Email
# Email address shown in payment confirmations and refund notifications
SUPPORT_EMAIL=support@sabieducate.com

# ============================================
# COMPANY INFORMATION (For Invoice Generation)
# ============================================
# Details to display on generated PDF invoices

COMPANY_NAME=Sabi Educate Ltd
COMPANY_ADDRESS=123 Business Street, London, UK
COMPANY_PHONE=+44-20-1234-5678

# ============================================
# WEBHOOK CONFIGURATION
# ============================================
# Configure these URLs in your Payoneer dashboard under Webhook settings

# Webhook Endpoint URL
# This is where Payoneer will send payment status updates
# Must be publicly accessible and use HTTPS
PAYONEER_WEBHOOK_URL=https://your-backend-domain.onrender.com/api/payments/webhook
